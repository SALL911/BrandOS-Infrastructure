{
  "name": "brandos-protocol-backend",
  "version": "1.0.0",
  "description": "BrandOS AI Infrastructure Protocol - Node.js Backend",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "jest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "build": "echo 'No build step required for Node.js'",
    "docker:build": "docker build -t brandos-backend .",
    "docker:run": "docker run -p 3000:3000 brandos-backend"
  },
  "keywords": [
    "brandos",
    "ai",
    "infrastructure",
    "protocol",
    "esg",
    "blockchain",
    "gpu",
    "scoring"
  ],
  "author": "BrandOS Protocol Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "mongoose": "^8.0.3",
    "redis": "^4.6.10",
    "bull": "^4.12.2",
    "axios": "^1.6.2",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "uuid": "^9.0.1",
    "crypto-js": "^4.2.0",
    "node-cron": "^3.0.3",
    "winston": "^3.11.0",
    "joi": "^17.11.0",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.1",
    "pdf-parse": "^1.1.1",
    "xlsx": "^0.18.5",
    "csv-parser": "^3.0.0",
    "archiver": "^6.0.1",
    "nodemailer": "^6.9.7",
    "twilio": "^4.19.0",
    "web3": "^4.2.2",
    "ethers": "^6.8.1",
    "did-jwt": "^3.1.3",
    "did-resolver": "^4.1.0",
    "ceramic-client": "^3.4.1",
    "ipfs-http-client": "^60.0.1",
    "node-forge": "^1.3.1",
    "zokrates-js": "^1.1.0",
    "snarkjs": "^0.7.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.55.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "prettier": "^3.1.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "@types/jest": "^29.5.8",
    "nock": "^13.4.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write",
      "git add"
    ]
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/app.js",
      "!src/config/database.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
