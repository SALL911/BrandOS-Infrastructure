# web/landing/.env.vercel.local — 複製這份到 .env.vercel.local 並填入真實值。
# 該檔案被 .gitignore 擋住（.env.*.local pattern），不會進 repo。
# 填完跑：bash scripts/vercel_env_push.sh web/landing/.env.vercel.local

# ─── Supabase（必要，lead/brand 寫入依賴）───
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiI...service-role-key...

# ─── Supabase client-side（若前端直連需要）───
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiI...anon-key...

# ─── Composio（Notion + Gmail 獲客管線）───
# 缺這些 /api/schema 與 /api/agent 仍會 200，但 Notion / Gmail 那兩條管線 degrade
COMPOSIO_API_KEY=composio_...
COMPOSIO_USER_ID=sall911-default
COMPOSIO_NOTION_LEAD_DB_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
COMPOSIO_NOTION_CONNECTION_ID=ca_...
COMPOSIO_GMAIL_CONNECTION_ID=ca_...

# ─── Stripe（$299 Audit / $1,999 Optimization checkout）───
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_AUDIT=price_...
STRIPE_PRICE_OPTIMIZATION=price_...

# ─── Google AI（Gemini 免費額度用於 /api/agent summary 強化）───
# 沒設的話 fallback 回 template summary，不影響交付
GOOGLE_GENERATIVE_AI_API_KEY=AIza...
