# Symcio Landing — Environment Variables
#
# 複製此檔為 .env.local 後填值；.env.local 已在 .gitignore 排除。
# Vercel 部署時，每一個 key 都要在 Settings → Environment Variables
# 設 Production + Preview 兩個環境（除非特別註記僅限 server）。

# ==========================================================
# Supabase（主資料庫 + Auth）
# ==========================================================
# 取得：Supabase Dashboard → Project Settings → API

# Server-only（Route Handlers / Middleware / Server Components）
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role-key...

# 前端 + 後端共用（cookies-based auth；瀏覽器也會讀）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon-public-key...

# ==========================================================
# Stripe（$299 Brand AI Audit 付款 + Pro subscription）
# ==========================================================
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Product / Price IDs（Dashboard 建立商品後取得；若走 checkout session 可略）
# STRIPE_PRICE_AUDIT_299=price_...
# STRIPE_PRICE_PRO_MONTHLY=price_...
# STRIPE_PRICE_PRO_YEARLY=price_...

# ==========================================================
# Typeform（Free Scan 入口，form ZZYlfK7A）
# ==========================================================
TYPEFORM_WEBHOOK_SECRET=generate-via-openssl-rand-base64-32

# ==========================================================
# GitHub repository_dispatch（觸發 GEO Audit workflow）
# ==========================================================
GH_DISPATCH_TOKEN=github_pat_...
GH_DISPATCH_REPO=SALL911/BrandOS-Infrastructure

# ==========================================================
# Resend（付款後寄報告 + 通知信）
# ==========================================================
RESEND_API_KEY=re_...

# ==========================================================
# AI Engines（geo_audit.py + 未來 agent 功能會用）
# ==========================================================
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
PERPLEXITY_API_KEY=

# ==========================================================
# 其他（選配）
# ==========================================================
# Site URL — 用於 email 連結、OAuth callback 組裝等
NEXT_PUBLIC_SITE_URL=https://symcio.tw

# Composio（Notion / HubSpot / Slack 等第三方整合）
# COMPOSIO_API_KEY=
# COMPOSIO_USER_ID=
# COMPOSIO_HUBSPOT_CONNECTION_ID=
