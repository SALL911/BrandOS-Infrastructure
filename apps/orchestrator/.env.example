# BrandOS AI Orchestrator — local dev environment template
# Copy to .env (gitignored) and fill in real values.

# ─── Frontend (artifacts/brandos, artifacts/mockup-sandbox) ───
# Both Vite configs assert these are set at startup.
PORT=5173
BASE_PATH=/

# ─── API server (artifacts/api-server) ───
# Drizzle expects a Postgres connection string. For first dev run,
# point this at a fresh Postgres (Supabase project, Vercel Postgres,
# local docker, etc.) and run: pnpm --filter @workspace/db push
DATABASE_URL=postgres://user:password@host:5432/orchestrator

# pino logger level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Standard Node hint
NODE_ENV=development
