# BrandOS Infrastructure — Environment Variables Template
# 複製此檔為 .env.local（不進 Git），填入實際值

# ==========================================================
# Supabase（主要資料庫）
# ==========================================================
# 取得方式：Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase CLI 連線（migration / db push 使用）
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_DB_PASSWORD=your-database-password
SUPABASE_ACCESS_TOKEN=your-personal-access-token

# 直接連線字串（server-side ORM / psql 使用）
# 格式：postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
SUPABASE_DB_URL=postgresql://postgres:password@db.ref.supabase.co:5432/postgres

# ==========================================================
# AI 引擎（GEO audit + BCI V-axis）
# ==========================================================
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# PERPLEXITY_API_KEY=

# ==========================================================
# BCI · Market Data Providers（F-axis）
# ==========================================================
# 預設 stack：yfinance (無需 key) + MOPS TW (無需 key)
# 選配：Alpha Vantage（500 req/day 免費）https://www.alphavantage.co/support/#api-key
# ALPHAVANTAGE_API_KEY=

# Bloomberg Terminal B-PIPE — 僅限**企業客戶自備 Terminal 訂閱**時啟用
# Symcio 不代理、不轉售、不散佈 Bloomberg 資料；adapter 為 stub，預設停用。
# BLOOMBERG_ENABLED=false
# BLOOMBERG_HOST=localhost
# BLOOMBERG_PORT=8194

# ==========================================================
# BCI · IP 權重（生產環境走 GitHub Secrets，本地測試可填）
# ==========================================================
# 權重向量屬核心 IP，不進 repo。本地開發用 private/bci/weights_dev.json 覆寫。
# BCI_WEIGHTS_JSON=
# BCI_INDUSTRY=technology

# ==========================================================
# 其他整合
# ==========================================================
# Composio — 統一 200+ app 整合（HubSpot / Gmail / Slack / Linear ...）
# COMPOSIO_API_KEY=
# COMPOSIO_USER_ID=
# COMPOSIO_HUBSPOT_CONNECTION_ID=

# Resend — 交易信（Free Scan 報告寄送）
# RESEND_API_KEY=

# Typeform — Free Scan 入口
# TYPEFORM_WEBHOOK_SECRET=

# GitHub — repository_dispatch 觸發 geo-audit
# GH_DISPATCH_TOKEN=
# GH_DISPATCH_REPO=SALL911/BrandOS-Infrastructure
