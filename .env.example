# BrandOS Infrastructure — Environment Variables Template
# 複製此檔為 .env.local（不進 Git），填入實際值

# ==========================================================
# Supabase（主要資料庫）
# ==========================================================
# 取得方式：Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase CLI 連線（migration / db push 使用）
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_DB_PASSWORD=your-database-password
SUPABASE_ACCESS_TOKEN=your-personal-access-token

# 直接連線字串（server-side ORM / psql 使用）
# 格式：postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
SUPABASE_DB_URL=postgresql://postgres:password@db.ref.supabase.co:5432/postgres

# ==========================================================
# 第三方整合（預留）
# ==========================================================
# BLOOMBERG_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
